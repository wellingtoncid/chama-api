{
    "name": "chama/api",
    "description": "API Chama Frete - Nova Estrutura Pro",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "firebase/php-jwt": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "cs-fixer": "php vendor/bin/php-cs-fixer fix",
        "cs-fixer:dry": "php vendor/bin/php-cs-fixer fix --dry-run",
        "test": "php vendor/bin/phpunit",
        "test:coverage": "php -d zend_extension=xdebug vendor/bin/phpunit --coverage-text",
        "coverage:html": "php -d zend_extension=xdebug vendor/bin/phpunit --coverage-html .coverage/html"
    }
}
